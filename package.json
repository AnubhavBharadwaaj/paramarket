{
  "name": "txline-agent",
  "version": "0.1.0",
  "description": "Proof-settled parametric prediction markets on TxLINE devnet",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --test tests/*.test.ts",
    "activate": "tsx src/client/activate.ts",
    "smoke": "tsx src/client/smoke.ts",
    "stage4:assets": "tsx scripts/generate-stage4-assets.ts",
    "stage2:e2e": "tsx tests/paramarket.ts",
    "check:evidence": "tsx scripts/check-evidence.ts",
    "save:evidence": "tsx scripts/save-evidence.ts",
    "refresh:evidence": "npm run stage2:e2e && npm run save:evidence && npm run check:evidence",
    "probe:tampers": "tsx scripts/probe-tampers.ts",
    "spike:settlement": "tsx src/client/settleSpike.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "buffer": "^6.0.3",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  }
}
